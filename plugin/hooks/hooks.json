{
  "description": "hybrid-coco hooks: suggest hc_* tools on Read/Grep, keep index fresh on Write/Edit",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/hc-pre-tool-use.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/hc-post-tool-use.sh",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ]
  }
}
